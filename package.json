{
  "name": "datadog-vercel-nextjs-otel-demo",
  "description": "Minimum-effort reference implementation for Next.js on Vercel with OpenTelemetry sending traces and logs to Datadog — using @vercel/otel, Sanity CMS, and Datadog RUM.",
  "keywords": [
    "Datadog",
    "OpenTelemetry",
    "Next.js",
    "Vercel",
    "Sanity",
    "APM",
    "RUM",
    "Observability"
  ],
  "homepage": "https://github.com/kyletaylored/datadog-sanity-vercel-demo#readme",
  "bugs": {
    "url": "https://github.com/kyletaylored/datadog-sanity-vercel-demo/issues"
  },
  "workspaces": [
    "studio",
    "frontend"
  ],
  "scripts": {
    "dev": "npx run-p --print-label dev:*",
    "dev:next": "npm run dev --workspace=frontend",
    "dev:studio": "npm run dev --workspace=studio",
    "format": "prettier --cache --write .",
    "import-sample-data": "cd studio && sanity dataset import sample-data.tar.gz --replace --dataset=production",
    "lint": "npm run lint --workspace=frontend",
    "type-check": "npm run type-check --workspaces"
  },
  "prettier": "@sanity/prettier-config",
  "devDependencies": {
    "@sanity/prettier-config": "^2.0.2",
    "npm-run-all2": "^5.0.2",
    "prettier": "^3.7.3"
  }
}