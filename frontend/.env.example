# Site URL — used as metadataBase for absolute OG image URLs.
# On Vercel this falls back to VERCEL_URL automatically. Set for custom domains.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

NEXT_PUBLIC_SANITY_PROJECT_ID="<paste your project here>" # Required - The ID of your Sanity project
NEXT_PUBLIC_SANITY_DATASET="production" # Required - The dataset of your Sanity project
NEXT_PUBLIC_SANITY_API_VERSION="2025-09-25" # Optional - The API version provided to the Sanity Client
NEXT_PUBLIC_SANITY_STUDIO_URL="" #Optional, defaults to http://localhost:3333
SANITY_API_READ_TOKEN="<paste your token here>" # Required - The read token for your Sanity project
SANITY_API_WRITE_TOKEN= # Required for lead capture form submissions (api/forms/lead). Create a token with Editor role in Sanity settings.

# Datadog API key — used by scripts/upload-sourcemaps.mjs at build time (never NEXT_PUBLIC_)
DATADOG_API_KEY=

# Repository URL for Datadog source code integration (auto-set on Vercel via VERCEL_GIT_* vars).
# Set manually for local dev so spans include git.repository_url.
GIT_REPO_URL=https://github.com/<owner>/<repo>

# Datadog RUM
NEXT_PUBLIC_DD_APPLICATION_ID=
NEXT_PUBLIC_DD_CLIENT_TOKEN=
NEXT_PUBLIC_DD_SITE=datadoghq.com

# Direct Datadog OTLP header — only required for local dev using the standard otlp.{site} endpoint.
# On Vercel, the vercel.integrations.otlp.{site} endpoint is used instead and does not need this.
DD_OTLP_SOURCE=

# Signal Lab env inspector passcode — protects the /api/lab/debug-env endpoint.
# Set to any secret string; matched server-side before returning process.env.
DEBUG_SECRET=

# Local dev OTLP — sends APM traces directly to Datadog when running outside Vercel.
# @vercel/otel reads VERCEL_OTEL_ENDPOINTS on Vercel; locally it falls back to these
# standard OTel env vars. Do NOT include /v1/traces — the SDK appends the signal path automatically.
# NOTE: The standard otlp.{site} endpoint requires dd-otlp-source (without it, Datadog returns 202
# but silently drops all spans). On Vercel, use vercel.integrations.otlp.{site} instead — it only
# needs dd-api-key.
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.datadoghq.com
OTEL_EXPORTER_OTLP_HEADERS=dd-api-key=<your-datadog-api-key>,dd-otlp-source=<your-dd-otlp-source>
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# OTLP Metrics — OTEL_EXPORTER_OTLP_ENDPOINT/HEADERS/PROTOCOL above already cover metrics.
# Only the temporality preference needs to be set explicitly: Datadog rejects cumulative
# sums with 400; delta (or gauge) is required.
# https://docs.datadoghq.com/opentelemetry/setup/otlp_ingest/metrics/
OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=delta

# Additional OTel resource attributes — merged automatically with programmatic attributes.
# Use this to add custom Datadog tags without code changes (set in Vercel project settings).
# service.name, deployment.environment, service.version, host.name, cloud.region, and
# deployment.id are already set programmatically from Vercel system env vars.
# OTEL_RESOURCE_ATTRIBUTES=team=platform,region=us-east-1

# These are auto-injected by Vercel — listed here for local dev awareness
# NEXT_PUBLIC_VERCEL_ENV=
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_REF=
# VERCEL_REGION=

# Injected automatically by the Vercel–Datadog integration at runtime.
# Do NOT set manually. Value contains a Datadog API key — avoid logging process.env in full.
# VERCEL_OTEL_ENDPOINTS=
