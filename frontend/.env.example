NEXT_PUBLIC_SANITY_PROJECT_ID="<paste your project here>" # Required - The ID of your Sanity project
NEXT_PUBLIC_SANITY_DATASET="production" # Required - The dataset of your Sanity project
NEXT_PUBLIC_SANITY_API_VERSION="2025-09-25" # Optional - The API version provided to the Sanity Client
NEXT_PUBLIC_SANITY_STUDIO_URL="" #Optional, defaults to http://localhost:3333
SANITY_API_READ_TOKEN="<paste your token here>" # Required - The read token for your Sanity project
SANITY_API_WRITE_TOKEN= # Required for lead capture form submissions (api/forms/lead). Create a token with Editor role in Sanity settings.

# Datadog API key — used by scripts/upload-sourcemaps.mjs at build time (never NEXT_PUBLIC_)
DATADOG_API_KEY=

# Datadog RUM
NEXT_PUBLIC_DD_APPLICATION_ID=
NEXT_PUBLIC_DD_CLIENT_TOKEN=
NEXT_PUBLIC_DD_SITE=datadoghq.com

# Direct Datadog OTLP header — value is a secret provided by Datadog.
# Only required for the Signal Lab "Direct OTLP Test" (api/lab/otel-direct).
# Sent as dd-otlp-source header on direct OTLP trace requests to https://otlp.{site}/v1/traces.
DD_OTLP_SOURCE=

# Signal Lab env inspector passcode — protects the /api/lab/debug-env endpoint.
# Set to any secret string; matched server-side before returning process.env.
DEBUG_SECRET=

# These are auto-injected by Vercel — listed here for local dev awareness
# NEXT_PUBLIC_VERCEL_PROJECT_NAME=
# NEXT_PUBLIC_VERCEL_ENV=
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_REF=
# VERCEL_REGION=

# Injected automatically by the Vercel–Datadog integration at runtime.
# Do NOT set manually. Value contains a Datadog API key — avoid logging process.env in full.
# VERCEL_OTEL_ENDPOINTS=
