{
  "name": "datadog-vercel-nextjs-frontend",
  "description": "Next.js frontend for the Datadog + Vercel + OTel demo — includes Signal Lab for triggering traces, logs, errors, and OTLP diagnostic tests.",
  "private": true,
  "scripts": {
    "prebuild": "sanity typegen generate",
    "build": "next build",
    "postbuild": "node scripts/upload-sourcemaps.mjs",
    "sourcemaps:dry-run": "node scripts/upload-sourcemaps.mjs --dry-run",
    "predev": "npm run sanity:typegen",
    "dev": "next dev --inspect",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sanity:typegen": "cd ../studio && sanity schema extract --enforce-required-fields --path ../sanity.schema.json && cd ../frontend && sanity typegen generate",
    "start": "next start",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@datadog/browser-logs": "^6.31.0",
    "@datadog/browser-rum": "^6.31.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.214.0",
    "@opentelemetry/instrumentation": "^0.213.0",
    "@opentelemetry/instrumentation-runtime-node": "^0.27.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@sanity/client": "^7.13.2",
    "@sanity/image-url": "^1.2.0",
    "@sanity/uuid": "^3.0.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/otel": "^2.1.1",
    "@vercel/speed-insights": "^1.2.0",
    "autoprefixer": "^10.4.22",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "next": "16.1.7",
    "next-sanity": "^12.0.5",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sanity": "^5.1.0",
    "sanity-image": "^1.0.0",
    "shiki": "^4.0.2",
    "simple-git": "^3.33.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.1.1",
    "typescript": "5.9.3"
  }
}
